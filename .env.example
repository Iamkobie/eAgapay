# ─── Supabase (public/anon key — safe to expose in frontend) ──────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── eGov SSO Backend ─────────────────────────────────────────────────────────
# The Express backend we built — handles exchange_code → Supabase session
VITE_API_URL=http://localhost:3000

# ─── eGov SSO ─────────────────────────────────────────────────────────────────
# eGov SSO login URL - user will be redirected here to authenticate
VITE_EGOV_SSO_URL=https://hackathon-sso.e.gov.ph/oauth/authorize
VITE_EGOV_PARTNER_CODE=HACKATHON_SSO
# The backend callback URL where eGov will redirect after login
VITE_EGOV_REDIRECT_URI=http://localhost:3000/api/auth/sso/callback

# ─── eGov AI ──────────────────────────────────────────────────────────────────
VITE_EGOV_AI_URL=https://egovai.e.gov.ph
VITE_EGOV_AI_ACCESS_CODE=your_egov_ai_access_code_here
